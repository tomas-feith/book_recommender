# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Virtual environments
.venv/
.venv39/
venv/

# Dataset build cache (downloaded source data)
.cache/

# Secrets
.env

# --- data/ -------------------------------------------------------------------
# Everything here is a build artifact EXCEPT the seed lists un-ignored below.
# Rebuild the rest with the pipeline in the README ("Building the data"):
#   real_books.json / real_profiles.json  <- build_real_dataset.py
#   coread-encoder/                       <- finetune_coread.py   (~130MB)
#   real_embeddings.npz                   <- build_embeddings.py
#   real_cf.npz                           <- refresh.py / cf_build.py
#   app.db                                <- created at runtime (per-user swipes)
data/*
!data/.gitkeep

# Hand-curated demo fixtures. No generator exists for these -- they are source,
# and `python -m eval.run` (the zero-dep baseline) reads them by default.
!data/sample_books.json
!data/sample_profiles.json

# Open Library snapshots. These CANNOT be regenerated: OL is a live catalog, so
# re-running the fetcher returns different books, not these. They are the seed
# lists that let `refresh.py --add` rebuild the same serving catalog, so they are
# source too -- despite the size.
!data/recent_books.json
!data/expansion_10k.json
!data/topup_head.json

# Coverage data
.coverage
coverage.xml
htmlcov/
